# KL7 Garage — Dealer Console environment variables
# Copy this file to .env.local and fill in the values.

# Base URL of your REST API (required only when VITE_USE_MOCK_API=false)
VITE_API_BASE_URL=https://api.kl7garage.in/v1

# Set to "false" to disable the built-in mock data layer and connect to a real backend.
# Default is "true" (mock enabled) — perfect for development and demos.
VITE_USE_MOCK_API=true
